# ============================================================================
# 生产部署环境变量模板 —— 复制为 .env 填真值;.env 已 gitignore,勿提交。
# docker compose -f docker-compose.prod.yml up -d 会自动读同目录 .env。
# ============================================================================

# ---- 必需 ----
# AI_MASTER_KEY:加密用户存在 DB 的 chat API key(AES-GCM master key)。
#   生产必须配,否则 CryptoUtil 退化为可预测的 dev 派生 key(安全漏洞)。
#   生成:openssl rand -base64 32
AI_MASTER_KEY=

# 数据库 / JWT(不填则用 docker-compose.prod.yml 的 :- 兜底默认,生产强烈建议改强值)
DB_PASSWORD=
JWT_SECRET=

# ---- 可选:RAG(设备手册检索) ----
# 默认关。要启用知识库检索,把 EMBEDDING/VECTORSTORE 设 openai/chroma 并填 embedding key。
# 注意:chat key 永远不在这里 —— chat 走每个用户在 UI 自配的 BYO-key,服务器零 chat key。
SPRING_AI_MODEL_EMBEDDING=none
SPRING_AI_VECTORSTORE_TYPE=none
SPRING_AI_OPENAI_EMBEDDING_API_KEY=
SPRING_AI_OPENAI_EMBEDDING_BASE_URL=https://api.siliconflow.cn
SPRING_AI_OPENAI_EMBEDDING_OPTIONS_MODEL=BAAI/bge-m3
