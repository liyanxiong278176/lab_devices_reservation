spring:
  ai:
    openai:
      # 聊天模型:DeepSeek OpenAI 兼容端点
      # 注册: https://platform.deepseek.com → API Keys
      base-url: https://api.deepseek.com/v1
      api-key: REPLACE_ME_WITH_DEEPSEEK_API_KEY
      chat:
        options:
          model: deepseek-v4-flash
          temperature: 0.3
          max-tokens: 4096
          stream-usage: true
      # 嵌入模型:硅基流动(bge-m3 中文 embedding 强)
      # 注册: https://cloud.siliconflow.cn → API 密钥
      embedding:
        base-url: https://api.siliconflow.cn/v1
        api-key: REPLACE_ME_WITH_SILICONFLOW_API_KEY
        options:
          model: BAAI/bge-m3
          dimensions: 1024
    vectorstore:
      chroma:
        url: http://chroma:8000
        collection-name: lab_manuals
        initialize-schema: true

ai:
  assistant:
    ratelimit:
      capacity: 20
      refill-per-minute: 20
    context-window-turns: 10
    pending-timeout-minutes: 5
    rag:
      top-k: 5
      similarity-threshold: 0.6
