spring:
  ai:
    openai:
      # 聊天模型:Xiaomi MiMo OpenAI 兼容端点
      # 注册: https://mimo.mi.com → API Keys
      base-url: https://token-plan-cn.xiaomimimo.com/v1
      api-key: REPLACE_ME_WITH_XIAOMI_API_KEY
      chat:
        options:
          model: mimo-v2.5
          temperature: 0.3
          max-tokens: 4096
          stream-usage: true

ai:
  assistant:
    ratelimit:
      capacity: 30
      refill-per-minute: 30
    context-window-turns: 10
    pending-timeout-minutes: 5