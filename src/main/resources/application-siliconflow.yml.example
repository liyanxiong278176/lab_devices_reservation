spring:
  ai:
    openai:
      # 聊天模型:DeepSeek OpenAI 兼容端点
      # 注册: https://platform.deepseek.com → API Keys
      base-url: https://api.deepseek.com
      api-key: REPLACE_ME_WITH_DEEPSEEK_API_KEY
      chat:
        options:
          model: deepseek-v4-flash
          temperature: 0.3
          max-tokens: 4096
          stream-usage: true

ai:
  assistant:
    ratelimit:
      capacity: 30
      refill-per-minute: 30
    context-window-turns: 10
    pending-timeout-minutes: 5
