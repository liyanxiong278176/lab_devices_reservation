<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="RabbitMQ双链路流程图">
    <mxGraphModel dx="1650" dy="1050" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1650" pageHeight="1050" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="RabbitMQ 双链路流程图  (a 异步通知 + 重试/DLX    b 延迟取消 TTL+死信)" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="1150" height="28" as="geometry" />
        </mxCell>

        <!-- ============ Chain (a) Async Notify ============ -->
        <mxCell id="cha" value="链路 a · 异步通知  (notify.exchange: direct / 重试3次 / 幂等 / DLX 兜底)" style="swimlane;startSize=28;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=14;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="30" y="55" width="1590" height="400" as="geometry" />
        </mxCell>

        <!-- Trigger sources -->
        <mxCell id="a_src" value="业务事件触发 (9 处)&#xa;———————————————&#xa;• 预约 create / cancel&#xa;• checkIn / checkOut&#xa;• 审批 approve / reject&#xa;• 报修 accept/resolve/reject&#xa;(均 TransactionSynchronization&#xa;afterCommit 内投递)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="cha">
          <mxGeometry x="20" y="45" width="200" height="160" as="geometry" />
        </mxCell>

        <!-- Producer -->
        <mxCell id="a_prod" value="NotificationProducer&#xa;notify(...)&#xa;rabbitTemplate.convertAndSend&#xa;(UUID msgId, afterCommit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="cha">
          <mxGeometry x="260" y="65" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Exchange -->
        <mxCell id="a_ex" value="notify.exchange&#xa;(DirectExchange)" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="cha">
          <mxGeometry x="510" y="65" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Queue -->
        <mxCell id="a_q" value="notify.queue&#xa;(x-dead-letter-exchange&#xa;= notify.dlx)" style="shape=mxgraph.flowchart.queue;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;direction=east;" vertex="1" parent="cha">
          <mxGeometry x="740" y="65" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Consumer -->
        <mxCell id="a_con" value="NotificationConsumer&#xa;@RabbitListener(notify.queue)&#xa;onMessage()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="cha">
          <mxGeometry x="970" y="65" width="190" height="70" as="geometry" />
        </mxCell>

        <!-- Redis idempotency -->
        <mxCell id="a_idem" value="Redis 幂等&#xa;SET NX mq:notify:{msgId}&#xa;TTL 24h&#xa;已存在 → 直接 ACK 丢弃" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="cha">
          <mxGeometry x="1200" y="65" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- Final service -->
        <mxCell id="a_svc" value="NotificationService.notify&#xa;INSERT notification(DB)&#xa;+ convertAndSendToUser&#xa;(STOMP 推送)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="cha">
          <mxGeometry x="1420" y="65" width="150" height="90" as="geometry" />
        </mxCell>

        <!-- arrows main chain -->
        <mxCell id="a_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=2;endArrow=classic;" edge="1" parent="cha" source="a_src" target="a_prod"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a_e2" value="routing-key=notify" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#9673a6;strokeWidth=2;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="cha" source="a_prod" target="a_ex"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a_e3" value="bind notify" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#9673a6;strokeWidth=2;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="cha" source="a_ex" target="a_q"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a_e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d6b656;strokeWidth=2;endArrow=classic;" edge="1" parent="cha" source="a_q" target="a_con"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a_e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b85450;strokeWidth=2;endArrow=classic;" edge="1" parent="cha" source="a_con" target="a_idem"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a_e6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d6b656;strokeWidth=2;endArrow=classic;" edge="1" parent="cha" source="a_idem" target="a_svc"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Retry / DLX branch -->
        <mxCell id="a_retry" value="Spring Retry 重试&#xa;max-attempts=3, initial 1s&#xa;default-requeue-rejected=false&#xa;(3 次仍失败 → 进死信)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;dashed=1;" vertex="1" parent="cha">
          <mxGeometry x="740" y="220" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="a_dlx" value="notify.dlx&#xa;(DirectExchange 死信)" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="cha">
          <mxGeometry x="980" y="225" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="a_dlq" value="notify.dlq&#xa;(死信队列 → 人工/告警)" style="shape=mxgraph.flowchart.queue;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;direction=east;" vertex="1" parent="cha">
          <mxGeometry x="1180" y="225" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="a_er1" value="消费异常" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b85450;strokeWidth=1.8;endArrow=classic;dashed=1;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="cha" source="a_con" target="a_retry"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a_er2" value="rejected → DLX" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b85450;strokeWidth=1.8;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="cha" source="a_q" target="a_dlx"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a_er3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#9673a6;strokeWidth=1.8;endArrow=classic;" edge="1" parent="cha" source="a_dlx" target="a_dlq"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="a_note" value="幂等键 = 消息 UUID; 重试期间不写库不推送; DB+STOMP 仅在首次成功消费执行." style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="cha">
          <mxGeometry x="740" y="320" width="700" height="20" as="geometry" />
        </mxCell>

        <!-- ============ Chain (b) Delay Cancel ============ -->
        <mxCell id="chb" value="链路 b · 延迟取消  (reservation.timeout.queue: per-msg TTL 无消费者 → 死信转发 → reservation.cancel.queue 消费)" style="swimlane;startSize=28;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=14;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="30" y="475" width="1590" height="400" as="geometry" />
        </mxCell>

        <!-- Trigger -->
        <mxCell id="b_src" value="审批通过事件&#xa;———————————————&#xa;ApprovalServiceImpl&#xa;approve()&#xa;PENDING → APPROVED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=6;" vertex="1" parent="chb">
          <mxGeometry x="20" y="60" width="190" height="120" as="geometry" />
        </mxCell>

        <!-- Producer -->
        <mxCell id="b_prod" value="ReservationTimeoutProducer&#xa;sendTimeout(reservationId, startTime)&#xa;per-msg TTL = (startTime-now)&#xa;+ graceMinutes×60000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="chb">
          <mxGeometry x="250" y="65" width="220" height="90" as="geometry" />
        </mxCell>

        <!-- TTL queue (no consumer) -->
        <mxCell id="b_tq" value="reservation.timeout.queue&#xa;(无消费者 · 每条消息独立 TTL&#xa;x-dead-letter-exchange =&gt;&#xa;reservation.cancel.exchange)" style="shape=mxgraph.flowchart.queue;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;direction=east;" vertex="1" parent="chb">
          <mxGeometry x="520" y="55" width="240" height="100" as="geometry" />
        </mxCell>

        <!-- dead-letter marker -->
        <mxCell id="b_dl" value="消息 TTL 到期&#xa;⬇ 死信 (dead-letter)" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;" vertex="1" parent="chb">
          <mxGeometry x="800" y="75" width="180" height="55" as="geometry" />
        </mxCell>

        <!-- Cancel exchange -->
        <mxCell id="b_cex" value="reservation.cancel.exchange&#xa;(DirectExchange)" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="chb">
          <mxGeometry x="1020" y="65" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- Cancel queue -->
        <mxCell id="b_cq" value="reservation.cancel.queue" style="shape=mxgraph.flowchart.queue;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;direction=east;" vertex="1" parent="chb">
          <mxGeometry x="1260" y="70" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Consumer -->
        <mxCell id="b_con" value="ReservationTimeoutConsumer&#xa;@RabbitListener(cancel.queue) onTimeout(id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="chb">
          <mxGeometry x="160" y="220" width="280" height="60" as="geometry" />
        </mxCell>

        <!-- Guard -->
        <mxCell id="b_guard" value="守卫: status == APPROVED ?&#xa;否 → 已被取消/完成/违规, 跳过 (幂等)&#xa;是 → 继续" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="chb">
          <mxGeometry x="490" y="200" width="240" height="110" as="geometry" />
        </mxCell>

        <!-- Actions -->
        <mxCell id="b_act1" value="reservationService&#xa;markTimeoutCancelled(id)&#xa;→ status=CANCELLED&#xa;cancel_reason=TIMEOUT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="chb">
          <mxGeometry x="780" y="215" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b_act2" value="notificationProducer.notify(...)&#xa;→ 进入链路 a&#xa;(通知用户「超时已自动取消」)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="chb">
          <mxGeometry x="1040" y="215" width="230" height="80" as="geometry" />
        </mxCell>

        <!-- arrows -->
        <mxCell id="b_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=2;endArrow=classic;" edge="1" parent="chb" source="b_src" target="b_prod"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="b_e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d6b656;strokeWidth=2;endArrow=classic;" edge="1" parent="chb" source="b_prod" target="b_tq"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="b_e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b85450;strokeWidth=2;endArrow=classic;" edge="1" parent="chb" source="b_tq" target="b_dl"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="b_e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#9673a6;strokeWidth=2;endArrow=classic;" edge="1" parent="chb" source="b_dl" target="b_cex"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="b_e5" value="routing=reservation.cancel" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#9673a6;strokeWidth=2;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="chb" source="b_cex" target="b_cq"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- cancel.queue down to consumer -->
        <mxCell id="b_e6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=2;endArrow=classic;" edge="1" parent="chb" source="b_cq" target="b_con"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="b_e7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d6b656;strokeWidth=2;endArrow=classic;" edge="1" parent="chb" source="b_con" target="b_guard"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="b_e8" value="是" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b85450;strokeWidth=2;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="chb" source="b_guard" target="b_act1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="b_e9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=2;endArrow=classic;" edge="1" parent="chb" source="b_act1" target="b_act2"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="b_note" value="延迟取消用 TTL+DLX 而非 RabbitMQ 延迟插件: 每条消息 TTL 不同(取决于预约开始时刻), 故不能用队列级 TTL; per-message TTL 到期后死信转发到 cancel.exchange, 落到 cancel.queue 被消费.&#xa;守卫保证仅 APPROVED 状态被取消 — 用户在此期间手动取消/完成的预约不会被重复处理 (MQ 至少一次投递下的应用层幂等)." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=#fffbe6;strokeColor=#d6b656;rounded=1;" vertex="1" parent="chb">
          <mxGeometry x="160" y="330" width="1110" height="55" as="geometry" />
        </mxCell>

        <!-- global legend -->
        <mxCell id="leg" value="异步投递调用点共 10 处: 9 处业务事件触发链路 a (预约 create/cancel/checkIn/checkOut · 审批 approve/reject · 报修 accept/resolve/reject) + 1 处 approve 触发链路 b 的 sendTimeout; 另: 链路 b 消费完成后回调链路 a (超时取消通知), 视为第 10 处系统自动 notify." style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fillColor=#fffbe6;strokeColor=#d6b656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="900" width="1590" height="45" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
