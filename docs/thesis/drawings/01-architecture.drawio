<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="系统架构图">
    <mxGraphModel dx="1280" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1280" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Title -->
        <mxCell id="title" value="实验室设备预约系统 — 总体架构图" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="340" y="10" width="600" height="30" as="geometry" />
        </mxCell>
        <!-- ===== Layer 1: Frontend ===== -->
        <mxCell id="fe" value="前端层 Frontend (浏览器)" style="swimlane;startSize=30;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="100" y="50" width="1080" height="130" as="geometry" />
        </mxCell>
        <mxCell id="fe1" value="Vue 3&#xa;Composition API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="fe">
          <mxGeometry x="40" y="45" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fe2" value="Element Plus&#xa;UI 组件库" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="fe">
          <mxGeometry x="180" y="45" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fe3" value="Pinia&#xa;状态管理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="fe">
          <mxGeometry x="320" y="45" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fe4" value="Vue Router&#xa;路由 / 守卫" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="fe">
          <mxGeometry x="460" y="45" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fe5" value="Axios&#xa;JWT 拦截器" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="fe">
          <mxGeometry x="600" y="45" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fe6" value="ECharts&#xa;数据可视化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="fe">
          <mxGeometry x="740" y="45" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fe7" value="STOMP / SockJS&#xa;实时推送客户端" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="fe">
          <mxGeometry x="880" y="45" width="160" height="60" as="geometry" />
        </mxCell>
        <!-- ===== Layer 2: nginx gateway ===== -->
        <mxCell id="ng" value="Nginx 反向代理网关 (端口 80)&#xa;location /api → app:8080   |   location /api/ws → STOMP(WebSocket)   |   静态资源 / 负载均衡 / HTTPS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="220" width="680" height="70" as="geometry" />
        </mxCell>
        <!-- ===== Layer 3: Business service ===== -->
        <mxCell id="svc" value="业务服务层  Spring Boot 3.2.5  ·  Java 17  ·  MyBatis-Plus  ·  Spring Security + JWT" style="swimlane;startSize=30;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="100" y="330" width="1080" height="180" as="geometry" />
        </mxCell>
        <mxCell id="m1" value="设备管理&#xa;Device" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="svc">
          <mxGeometry x="40" y="45" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m2" value="预约管理&#xa;Reservation&#xa;(Redisson 锁)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="svc">
          <mxGeometry x="180" y="45" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m3" value="审批&#xa;Approval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="svc">
          <mxGeometry x="330" y="45" width="110" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m4" value="报修&#xa;Repair" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="svc">
          <mxGeometry x="460" y="45" width="110" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m5" value="混合推荐&#xa;Recommendation&#xa;(加权评分)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="svc">
          <mxGeometry x="590" y="45" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m6" value="通知服务&#xa;Notification&#xa;(STOMP 推送)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="svc">
          <mxGeometry x="750" y="45" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m7" value="数据看板&#xa;Dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="svc">
          <mxGeometry x="910" y="45" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m8" value="四大技术亮点:  ① Redisson 分布式锁(MultiLock)    ② STOMP/SockJS 实时推送    ③ ECharts 看板    ④ 混合启发式推荐&#xa;横切:  统一异常处理 · JWT 鉴权 · 操作日志(operation_log) · 参数校验" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="svc">
          <mxGeometry x="40" y="115" width="990" height="45" as="geometry" />
        </mxCell>
        <!-- ===== Layer 4: Middleware ===== -->
        <mxCell id="mw" value="中间件 / 数据层 Middleware" style="swimlane;startSize=30;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=13;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="100" y="560" width="1080" height="150" as="geometry" />
        </mxCell>
        <mxCell id="db1" value="MySQL 8.0&#xa;持久化存储&#xa;(业务表 + 唯一索引)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;boundedLbl=1;" vertex="1" parent="mw">
          <mxGeometry x="90" y="45" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="db2" value="Redis 7&#xa;缓存 · 会话&#xa;Redisson 分布式锁" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;boundedLbl=1;" vertex="1" parent="mw">
          <mxGeometry x="440" y="45" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="db3" value="RabbitMQ 3.13&#xa;异步通知解耦&#xa;TTL+DLX 延迟队列" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;boundedLbl=1;" vertex="1" parent="mw">
          <mxGeometry x="790" y="45" width="200" height="90" as="geometry" />
        </mxCell>
        <!-- ===== Edges ===== -->
        <!-- frontend -> nginx -->
        <mxCell id="e1" value="HTTPS  /  WebSocket" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#d79b00;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fe" target="ng">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- nginx -> service -->
        <mxCell id="e2" value="反向代理 /api  ·  /api/ws" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#d79b00;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="ng" target="svc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- service -> MySQL -->
        <mxCell id="e3" value="MyBatis-Plus / JDBC" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.2;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#82b366;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="svc" target="db1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- service -> Redis -->
        <mxCell id="e4" value="缓存 / Redisson 锁" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#b85450;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="svc" target="db2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- service -> RabbitMQ -->
        <mxCell id="e5" value="AMQP 收发" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.8;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#9673a6;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="svc" target="db3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Legend -->
        <mxCell id="leg" value="图例:  ━━ 业务调用 / 数据流      框内黄色块 = 四大技术亮点模块" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fillColor=none;strokeColor=none;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="100" y="740" width="600" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
