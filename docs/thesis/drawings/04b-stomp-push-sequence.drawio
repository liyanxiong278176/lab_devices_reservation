<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="STOMP实时推送时序图">
    <mxGraphModel dx="1350" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1350" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="亮点②  STOMP/SockJS 实时推送时序图  (握手鉴权 + Principal 点对点投递)" style="text;html=1;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="950" height="28" as="geometry" />
        </mxCell>

        <!-- ===== Lifelines ===== -->
        <mxCell id="ll_fe" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="145" y="110" width="10" height="620" as="geometry" />
        </mxCell>
        <mxCell id="ll_int" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="415" y="110" width="10" height="620" as="geometry" />
        </mxCell>
        <mxCell id="ll_h" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="675" y="110" width="10" height="620" as="geometry" />
        </mxCell>
        <mxCell id="ll_reg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;dashed=1;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="935" y="110" width="10" height="620" as="geometry" />
        </mxCell>
        <mxCell id="ll_ns" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="1185" y="110" width="10" height="620" as="geometry" />
        </mxCell>

        <!-- ===== Headers ===== -->
        <mxCell id="h_fe" value="前端 SockJS&#xa;stompClient" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="65" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h_int" value="WsAuthHandshakeInterceptor&#xa;beforeHandshake()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="65" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h_h" value="JwtHandshakeHandler&#xa;determineUser()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="580" y="65" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h_reg" value="SimpMessagingTemplate /&#xa;SimpUserRegistry (Broker)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="835" y="65" width="210" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h_ns" value="NotificationServiceImpl&#xa;notify()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1090" y="65" width="200" height="40" as="geometry" />
        </mxCell>

        <!-- ===== Phase A: Handshake ===== -->
        <mxCell id="ph_a" value="阶段 A · WebSocket 握手鉴权" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="135" width="300" height="20" as="geometry" />
        </mxCell>
        <!-- 1. FE -> Interceptor -->
        <mxCell id="m1" value="① new SockJS('/ws?token=Bearer xxx')  HTTP Upgrade" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;endArrow=classic;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="155" y="170" as="sourcePoint" />
            <mxPoint x="415" y="170" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- 2. Interceptor self -->
        <mxCell id="m2" value="② getParameter(&quot;token&quot;) → 去 Bearer → jwtUtils.parseUserId&#xa;attributes.put(&quot;wsUserId&quot;, userId) ; 无效 token → return false 拒绝握手" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82b366;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;endArrow=classic;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=1;entryY=0.75;entryDx=0;entryDy=0;" edge="1" parent="1" source="ll_int" target="ll_int">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 3. Interceptor -> Handler -->
        <mxCell id="m3" value="③ 握手继续, 透传 attributes(wsUserId)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82b366;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;endArrow=classic;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="425" y="235" as="sourcePoint" />
            <mxPoint x="675" y="235" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- 4. Handler self: determineUser -->
        <mxCell id="m4" value="④ determineUser: 读 wsUserId →&#xa;Principal( () -&gt; String.valueOf(userId) )" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#82b366;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;endArrow=classic;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=1;entryY=0.75;entryDx=0;entryDy=0;" edge="1" parent="1" source="ll_h" target="ll_h">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 5. Handler -> Registry -->
        <mxCell id="m5" value="⑤ 注册会话, user = userId (Principal.getName)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;endArrow=classic;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="685" y="300" as="sourcePoint" />
            <mxPoint x="935" y="300" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- 6. Registry -> FE: STOMP CONNECTED -->
        <mxCell id="m6" value="⑥ STOMP CONNECTED ✅ (前端订阅 /user/queue/notifications)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;endArrow=classic;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="935" y="340" as="sourcePoint" />
            <mxPoint x="155" y="340" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ===== Phase B: Push ===== -->
        <mxCell id="ph_b" value="阶段 B · 业务事件触发的点对点推送" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="40" y="385" width="400" height="20" as="geometry" />
        </mxCell>
        <!-- 7. Trigger -> NotificationService (note) -->
        <mxCell id="m7" value="⑦ 触发源: 预约/审批/报修/超时取消 等业务事件 → 经 MQ 异步到达" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1090" y="410" width="240" height="40" as="geometry" />
        </mxCell>
        <!-- 8. NotificationService self: DB + send -->
        <mxCell id="m8" value="⑧ INSERT notification(DB) + convertAndSendToUser&#xa;(userId, &quot;/queue/notifications&quot;, payload)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d6b656;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;endArrow=classic;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=1;entryY=0.75;entryDx=0;entryDy=0;" edge="1" parent="1" source="ll_ns" target="ll_ns">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 9. NotificationService -> Broker -->
        <mxCell id="m9" value="⑨ 按 user 前缀解析 → 查 SimpUserRegistry 找在线会话" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d6b656;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;endArrow=classic;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1185" y="490" as="sourcePoint" />
            <mxPoint x="945" y="490" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- 10. Broker -> FE -->
        <mxCell id="m10" value="⑩ 仅投递给 userId 对应的活跃 Session (点对点, 不广播)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;endArrow=classic;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="935" y="540" as="sourcePoint" />
            <mxPoint x="155" y="540" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- 11. FE self: toast -->
        <mxCell id="m11" value="⑪ subscribe 回调 → ElMessage / Notification toast 🔔" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;labelBackgroundColor=#ffffff;endArrow=classic;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=1;entryY=0.75;entryDx=0;entryDy=0;" edge="1" parent="1" source="ll_fe" target="ll_fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Note -->
        <mxCell id="note1" value="关键设计:&#xa;• 鉴权在握手期(beforeHandshake) 用 ?token= query 参数完成 — 因 WebSocket 浏览器无法附加自定义 Header.&#xa;• JwtHandshakeHandler.determineUser 注入 Principal, 使 SimpUserRegistry 以 userId 标识会话, 后续 convertAndSendToUser 才能「按用户定向」.&#xa;• 端点 /ws + withSockJS(); broker 前缀 /queue, user 前缀 /user; 前端订阅 /user/queue/notifications.&#xa;• 无效 token 直接 beforeHandshake return false, 拒绝建立连接 (不进入 STOMP 层)." style="text;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=#fffbe6;strokeColor=#d6b656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="720" width="950" height="100" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
