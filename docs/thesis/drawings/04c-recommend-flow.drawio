<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="混合推荐数据流图">
    <mxGraphModel dx="1300" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="亮点④  混合启发式推荐数据流图  (加权评分 + 可解释理由 + 冷启动回退)" style="text;html=1;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="900" height="28" as="geometry" />
        </mxCell>

        <!-- ===== Source ===== -->
        <mxCell id="src" value="用户行为数据源: reservation (预约历史表)&#xa;recommend() → 取该用户全部历史预约作为行为画像 (operation_log 不参与)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="380" y="60" width="540" height="55" as="geometry" />
        </mxCell>

        <!-- ===== Feature extraction (5 boxes) ===== -->
        <mxCell id="f1" value="特征① 类目亲和度&#xa;categoryAffinity&#xa;catCounts/total (0..1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="170" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f2" value="特征② 实验室亲和度&#xa;labAffinity&#xa;labCounts/total (0..1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="270" y="170" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f3" value="特征③ 热度&#xa;popularity&#xa;近30天预约数/maxPop (0..1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="510" y="170" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f4" value="特征④ 标签匹配&#xa;tagMatch&#xa;|tags∩prefTags|/|prefTags|" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="750" y="170" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f5" value="特征⑤ 已用惩罚&#xa;usedPenalty&#xa;有活跃预约则扣 ε" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="990" y="170" width="220" height="70" as="geometry" />
        </mxCell>

        <!-- arrows source -> features -->
        <mxCell id="e_s1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#6c8ebf;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="src" target="f1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_s2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#6c8ebf;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="src" target="f2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_s3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#6c8ebf;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="src" target="f3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_s4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#6c8ebf;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="src" target="f4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_s5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#6c8ebf;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="src" target="f5"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ===== Weighted score formula ===== -->
        <mxCell id="score" value="加权评分公式  Score = α·categoryAffinity + β·labAffinity + γ·popularity + δ·tagMatch − ε·usedPenalty&#xa;α=0.40 (类目)   β=0.20 (实验室)   γ=0.25 (热度)   δ=0.10 (标签)   ε=0.30 (已用惩罚)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=13;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="200" y="290" width="900" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e_f1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="f1" target="score"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_f2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="f2" target="score"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_f3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="f3" target="score"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_f4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="f4" target="score"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_f5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b85450;strokeWidth=1.5;endArrow=classic;" edge="1" parent="1" source="f5" target="score"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ===== Candidate filter ===== -->
        <mxCell id="candfilter" value="候选过滤:  仅对 status = IDLE 的设备评分 (排除 IN_USE / MAINTENANCE)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="400" width="700" height="45" as="geometry" />
        </mxCell>
        <mxCell id="e_sc1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d6b656;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="score" target="candfilter"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ===== Redis cache + TopN ===== -->
        <mxCell id="cache" value="Redis 缓存  rec:u:{userId}  (TTL 5min, MAX_CACHE_SIZE=50)&#xa;compute() 重算后写回" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="475" width="340" height="50" as="geometry" />
        </mxCell>
        <mxCell id="topn" value="排序取 TopN&#xa;recommend(userId, limit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="660" y="475" width="340" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e_fl" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#9673a6;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="candfilter" target="cache"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_ct" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#9673a6;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="cache" target="topn"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ===== Reason picker ===== -->
        <mxCell id="reason" value="可解释理由生成  pickReason()&#xa;取贡献最大的维度 → 模板拼装 (ε=0.01 平票阈值; 优先级 类目&gt;实验室&gt;标签&gt;热度)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="560" width="700" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e_tr" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="topn" target="reason"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ===== Response ===== -->
        <mxCell id="resp" value="响应  GET /recommendations?limit=N&#xa;[{ deviceId, score, reason: &quot;因你常约【示波器】类目&quot; | &quot;因你常用【电子实验室】&quot; | &quot;标签匹配你的偏好&quot; | &quot;近30天热门设备&quot; }]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="650" width="900" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e_rr" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d6b656;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="reason" target="resp"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ===== Cold-start branch (right) ===== -->
        <mxCell id="cold_title" value="冷启动分支" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1020" y="400" width="220" height="22" as="geometry" />
        </mxCell>
        <mxCell id="cold1" value="判定: total = 0&#xa;(用户无历史预约)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1040" y="430" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cold2" value="亲和度/标签特征全为 0&#xa;Score 退化为 γ·popularity&#xa;→ reason = &quot;近30天热门设备&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1020" y="540" width="220" height="75" as="geometry" />
        </mxCell>
        <mxCell id="e_c1" value="是 (无画像)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b85450;strokeWidth=2;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="cold1" target="cold2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_c0" value="否" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=2;endArrow=classic;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="cold1" target="candfilter"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_c2" value="热度兜底" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d6b656;strokeWidth=2;endArrow=classic;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="cold2" target="resp"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- note -->
        <mxCell id="note" value="设计要点:  五维特征均归一化到 [0,1] 后加权求和, 保证可比; 权重经 application-dev.yml 外部化配置便于调参; 已用惩罚为负项避免重复推荐用户已占用的设备; 理由随最高权重维度动态生成, 满足论文「可解释推荐」诉求." style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fillColor=#fffbe6;strokeColor=#d6b656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="740" width="900" height="50" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
