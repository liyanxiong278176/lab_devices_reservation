<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="ER实体关系图">
    <mxGraphModel dx="1400" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Title -->
        <mxCell id="title" value="核心数据表 ER 实体关系图（9 张业务表 · 隐式外键 · uk_device_date_slot 硬防超约）" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="1000" height="30" as="geometry" />
        </mxCell>

        <!-- ===== Row 1: sys_user / lab / device_category ===== -->
        <mxCell id="t_user" value="&lt;b style='font-size:13px'&gt;sys_user&lt;/b&gt;&lt;hr style='margin:2px 0'/&gt;&lt;div&gt;&lt;b&gt;&lt;u&gt;PK&lt;/u&gt;&lt;/b&gt; id : BIGINT&lt;/div&gt;&lt;div&gt;username : VARCHAR(64) &lt;i&gt;[UNIQUE]&lt;/i&gt;&lt;/div&gt;&lt;div&gt;password : VARCHAR(100)&lt;/div&gt;&lt;div&gt;real_name : VARCHAR(50)&lt;/div&gt;&lt;div&gt;phone / email&lt;/div&gt;&lt;div&gt;user_type : VARCHAR(20)  &lt;i&gt;(STUDENT/LAB_ADMIN/SYS_ADMIN)&lt;/i&gt;&lt;/div&gt;&lt;div&gt;dept_name : VARCHAR(100)&lt;/div&gt;&lt;div&gt;status : TINYINT  &lt;i&gt;(0禁 1用)&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;created_at, updated_at&lt;/i&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="260" height="190" as="geometry" />
        </mxCell>

        <mxCell id="t_lab" value="&lt;b style='font-size:13px'&gt;lab&lt;/b&gt;&lt;hr style='margin:2px 0'/&gt;&lt;div&gt;&lt;b&gt;&lt;u&gt;PK&lt;/u&gt;&lt;/b&gt; id : BIGINT&lt;/div&gt;&lt;div&gt;name : VARCHAR(100)&lt;/div&gt;&lt;div&gt;location : VARCHAR(200)&lt;/div&gt;&lt;div&gt;&lt;b&gt;FK&lt;/b&gt; manager_id : BIGINT&lt;/div&gt;&lt;div&gt;description : VARCHAR(500)&lt;/div&gt;&lt;div&gt;status : TINYINT&lt;/div&gt;&lt;div&gt;&lt;i&gt;created_at, updated_at&lt;/i&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="570" y="60" width="260" height="150" as="geometry" />
        </mxCell>

        <mxCell id="t_cat" value="&lt;b style='font-size:13px'&gt;device_category&lt;/b&gt;&lt;hr style='margin:2px 0'/&gt;&lt;div&gt;&lt;b&gt;&lt;u&gt;PK&lt;/u&gt;&lt;/b&gt; id : BIGINT&lt;/div&gt;&lt;div&gt;name : VARCHAR(100)&lt;/div&gt;&lt;div&gt;&lt;b&gt;FK&lt;/b&gt; parent_id : BIGINT  &lt;i&gt;(self-ref)&lt;/i&gt;&lt;/div&gt;&lt;div&gt;sort : INT&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1100" y="60" width="260" height="110" as="geometry" />
        </mxCell>

        <!-- ===== Row 2: notification / device / reservation ===== -->
        <mxCell id="t_notif" value="&lt;b style='font-size:13px'&gt;notification&lt;/b&gt;&lt;hr style='margin:2px 0'/&gt;&lt;div&gt;&lt;b&gt;&lt;u&gt;PK&lt;/u&gt;&lt;/b&gt; id : BIGINT&lt;/div&gt;&lt;div&gt;&lt;b&gt;FK&lt;/b&gt; user_id : BIGINT&lt;/div&gt;&lt;div&gt;type : VARCHAR(50)&lt;/div&gt;&lt;div&gt;title : VARCHAR(200)&lt;/div&gt;&lt;div&gt;content : VARCHAR(1000)&lt;/div&gt;&lt;div&gt;related_id : BIGINT  &lt;i&gt;(多态)&lt;/i&gt;&lt;/div&gt;&lt;div&gt;related_type : VARCHAR(50)&lt;/div&gt;&lt;div&gt;is_read : TINYINT&lt;/div&gt;&lt;div&gt;&lt;i&gt;created_at&lt;/i&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="260" height="180" as="geometry" />
        </mxCell>

        <mxCell id="t_device" value="&lt;b style='font-size:13px'&gt;device&lt;/b&gt;&lt;hr style='margin:2px 0'/&gt;&lt;div&gt;&lt;b&gt;&lt;u&gt;PK&lt;/u&gt;&lt;/b&gt; id : BIGINT&lt;/div&gt;&lt;div&gt;name : VARCHAR(100)&lt;/div&gt;&lt;div&gt;&lt;b&gt;FK&lt;/b&gt; category_id : BIGINT&lt;/div&gt;&lt;div&gt;&lt;b&gt;FK&lt;/b&gt; lab_id : BIGINT&lt;/div&gt;&lt;div&gt;brand / model / specs&lt;/div&gt;&lt;div&gt;image_url : VARCHAR(500)&lt;/div&gt;&lt;div&gt;status : VARCHAR(20)  &lt;i&gt;(IDLE/IN_USE/MAINTENANCE)&lt;/i&gt;&lt;/div&gt;&lt;div&gt;need_approval : TINYINT&lt;/div&gt;&lt;div&gt;max_reservation_hours : DECIMAL(5,2)&lt;/div&gt;&lt;div&gt;price_per_hour : DECIMAL(10,2)&lt;/div&gt;&lt;div&gt;tags : JSON&lt;/div&gt;&lt;div&gt;description : TEXT&lt;/div&gt;&lt;div&gt;&lt;i&gt;created_at, updated_at&lt;/i&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="570" y="300" width="260" height="260" as="geometry" />
        </mxCell>

        <mxCell id="t_res" value="&lt;b style='font-size:13px'&gt;reservation&lt;/b&gt;&lt;hr style='margin:2px 0'/&gt;&lt;div&gt;&lt;b&gt;&lt;u&gt;PK&lt;/u&gt;&lt;/b&gt; id : BIGINT&lt;/div&gt;&lt;div&gt;&lt;b&gt;FK&lt;/b&gt; user_id : BIGINT&lt;/div&gt;&lt;div&gt;&lt;b&gt;FK&lt;/b&gt; device_id : BIGINT&lt;/div&gt;&lt;div&gt;purpose : VARCHAR(500)&lt;/div&gt;&lt;div&gt;start_time / end_time : DATETIME&lt;/div&gt;&lt;div&gt;slot_count : INT&lt;/div&gt;&lt;div&gt;status : VARCHAR(20)  &lt;i&gt;(8态枚举)&lt;/i&gt;&lt;/div&gt;&lt;div&gt;cancel_reason : VARCHAR(32)  &lt;i&gt;(USER/TIMEOUT)&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;FK&lt;/b&gt; approver_id : BIGINT&lt;/div&gt;&lt;div&gt;approved_at : DATETIME&lt;/div&gt;&lt;div&gt;reject_reason : VARCHAR(500)&lt;/div&gt;&lt;div&gt;check_in_at / check_out_at&lt;/div&gt;&lt;div&gt;&lt;i&gt;created_at, updated_at&lt;/i&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1100" y="300" width="260" height="280" as="geometry" />
        </mxCell>

        <!-- ===== Row 3: repair_report / reservation_item / operation_log ===== -->
        <mxCell id="t_repair" value="&lt;b style='font-size:13px'&gt;repair_report&lt;/b&gt;&lt;hr style='margin:2px 0'/&gt;&lt;div&gt;&lt;b&gt;&lt;u&gt;PK&lt;/u&gt;&lt;/b&gt; id : BIGINT&lt;/div&gt;&lt;div&gt;&lt;b&gt;FK&lt;/b&gt; device_id : BIGINT&lt;/div&gt;&lt;div&gt;&lt;b&gt;FK&lt;/b&gt; reporter_id : BIGINT&lt;/div&gt;&lt;div&gt;title : VARCHAR(200)&lt;/div&gt;&lt;div&gt;description : TEXT&lt;/div&gt;&lt;div&gt;image_urls : JSON&lt;/div&gt;&lt;div&gt;status : VARCHAR(20)&lt;/div&gt;&lt;div&gt;&lt;b&gt;FK&lt;/b&gt; handler_id : BIGINT&lt;/div&gt;&lt;div&gt;resolution_note : VARCHAR(500)&lt;/div&gt;&lt;div&gt;resolved_at : DATETIME&lt;/div&gt;&lt;div&gt;&lt;i&gt;created_at, updated_at&lt;/i&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="720" width="260" height="220" as="geometry" />
        </mxCell>

        <mxCell id="t_item" value="&lt;b style='font-size:13px'&gt;reservation_item&lt;/b&gt;&lt;hr style='margin:2px 0'/&gt;&lt;div&gt;&lt;b&gt;&lt;u&gt;PK&lt;/u&gt;&lt;/b&gt; id : BIGINT&lt;/div&gt;&lt;div&gt;&lt;b&gt;FK&lt;/b&gt; reservation_id : BIGINT&lt;/div&gt;&lt;div&gt;&lt;b&gt;FK&lt;/b&gt; device_id : BIGINT&lt;/div&gt;&lt;div&gt;date : DATE&lt;/div&gt;&lt;div&gt;slot_index : INT&lt;/div&gt;&lt;hr style='margin:2px 0'/&gt;&lt;div style='background:#fff2cc'&gt;&lt;b&gt;UNIQUE&lt;/b&gt; uk_device_date_slot&lt;/div&gt;&lt;div style='background:#fff2cc'&gt;(device_id, date, slot_index)&lt;/div&gt;&lt;div style='background:#fff2cc'&gt;&lt;i&gt;COMMENT '硬防超约' — 双重防御兜底&lt;/i&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="570" y="720" width="260" height="200" as="geometry" />
        </mxCell>

        <mxCell id="t_log" value="&lt;b style='font-size:13px'&gt;operation_log&lt;/b&gt;&lt;hr style='margin:2px 0'/&gt;&lt;div&gt;&lt;b&gt;&lt;u&gt;PK&lt;/u&gt;&lt;/b&gt; id : BIGINT&lt;/div&gt;&lt;div&gt;&lt;b&gt;FK&lt;/b&gt; user_id : BIGINT&lt;/div&gt;&lt;div&gt;username : VARCHAR(64)  &lt;i&gt;(冗余)&lt;/i&gt;&lt;/div&gt;&lt;div&gt;action : VARCHAR(200)&lt;/div&gt;&lt;div&gt;method : VARCHAR(200)&lt;/div&gt;&lt;div&gt;params : TEXT&lt;/div&gt;&lt;div&gt;ip : VARCHAR(50)&lt;/div&gt;&lt;div&gt;cost_ms : BIGINT&lt;/div&gt;&lt;div&gt;&lt;i&gt;created_at&lt;/i&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1100" y="720" width="260" height="180" as="geometry" />
        </mxCell>

        <!-- ===== Edges (FK relationships) ===== -->
        <!-- lab.manager_id -> sys_user.id -->
        <mxCell id="fk1" value="manager_id  N:1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeColor=#6c8ebf;strokeWidth=1.5;fontSize=10;labelBackgroundColor=#ffffff;endArrow=ERmany;startArrow=ERone;" edge="1" parent="1" source="t_lab" target="t_user">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- device.category_id -> device_category.id -->
        <mxCell id="fk2" value="category_id  N:1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeColor=#82b366;strokeWidth=1.5;fontSize=10;labelBackgroundColor=#ffffff;endArrow=ERmany;startArrow=ERone;" edge="1" parent="1" source="t_device" target="t_cat">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- device.lab_id -> lab.id -->
        <mxCell id="fk3" value="lab_id  N:1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeColor=#82b366;strokeWidth=1.5;fontSize=10;labelBackgroundColor=#ffffff;endArrow=ERmany;startArrow=ERone;" edge="1" parent="1" source="t_device" target="t_lab">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- reservation.user_id -> sys_user.id -->
        <mxCell id="fk4" value="user_id  N:1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeColor=#b85450;strokeWidth=1.5;fontSize=10;labelBackgroundColor=#ffffff;endArrow=ERmany;startArrow=ERone;" edge="1" parent="1" source="t_res" target="t_user">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- reservation.device_id -> device.id -->
        <mxCell id="fk5" value="device_id  N:1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeColor=#b85450;strokeWidth=1.5;fontSize=10;labelBackgroundColor=#ffffff;endArrow=ERmany;startArrow=ERone;" edge="1" parent="1" source="t_res" target="t_device">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- reservation.approver_id -> sys_user.id -->
        <mxCell id="fk6" value="approver_id  N:1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;dashed=1;strokeColor=#b85450;strokeWidth=1.5;fontSize=10;labelBackgroundColor=#ffffff;endArrow=ERmany;startArrow=ERone;" edge="1" parent="1" source="t_res" target="t_user">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- reservation_item.reservation_id -> reservation.id -->
        <mxCell id="fk7" value="reservation_id  N:1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeColor=#b85450;strokeWidth=2;fontSize=10;fontStyle=1;labelBackgroundColor=#ffffff;endArrow=ERmany;startArrow=ERone;" edge="1" parent="1" source="t_item" target="t_res">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- reservation_item.device_id -> device.id -->
        <mxCell id="fk8" value="device_id  N:1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeColor=#b85450;strokeWidth=1.5;fontSize=10;labelBackgroundColor=#ffffff;endArrow=ERmany;startArrow=ERone;" edge="1" parent="1" source="t_item" target="t_device">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- notification.user_id -> sys_user.id -->
        <mxCell id="fk9" value="user_id  N:1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeColor=#d6b656;strokeWidth=1.5;fontSize=10;labelBackgroundColor=#ffffff;endArrow=ERmany;startArrow=ERone;" edge="1" parent="1" source="t_notif" target="t_user">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- repair_report.device_id -> device.id -->
        <mxCell id="fk10" value="device_id  N:1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeColor=#9673a6;strokeWidth=1.5;fontSize=10;labelBackgroundColor=#ffffff;endArrow=ERmany;startArrow=ERone;" edge="1" parent="1" source="t_repair" target="t_device">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- repair_report.reporter_id -> sys_user.id -->
        <mxCell id="fk11" value="reporter_id  N:1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeColor=#9673a6;strokeWidth=1.5;fontSize=10;labelBackgroundColor=#ffffff;endArrow=ERmany;startArrow=ERone;" edge="1" parent="1" source="t_repair" target="t_user">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- operation_log.user_id -> sys_user.id -->
        <mxCell id="fk12" value="user_id  N:1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;strokeColor=#666666;strokeWidth=1.5;fontSize=10;labelBackgroundColor=#ffffff;endArrow=ERmany;startArrow=ERone;" edge="1" parent="1" source="t_log" target="t_user">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="leg" value="图例:  &lt;b&gt;&lt;u&gt;PK&lt;/u&gt;&lt;/b&gt; 主键   &lt;b&gt;FK&lt;/b&gt; 外键(隐式,应用层校验)   &lt;i&gt;[UNIQUE]&lt;/i&gt; 唯一索引   红色实体=预约核心表   黄色=通知   绿色=设备/实验室   紫=报修   灰=日志&#xa;注: 表间无声明式 FOREIGN KEY 约束,关系通过命名约定+Service 层保证;reservation_item.uk_device_date_slot 是并发兜底的 DB 唯一索引。" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=#fffbe6;strokeColor=#d6b656;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="970" width="1320" height="60" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
